# === Snowflake ===
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=PERF_TESTING
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=PERF_WH
SNOWFLAKE_ROLE=PERF_ENGINEER

# === Dynatrace ===
